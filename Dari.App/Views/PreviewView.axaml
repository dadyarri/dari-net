<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Dari.App.ViewModels"
             x:Class="Dari.App.Views.PreviewView"
             x:DataType="vm:PreviewViewModel"
             HorizontalAlignment="Stretch"
             VerticalAlignment="Stretch">

    <Panel>

        <!-- Empty: no entry selected -->
        <TextBlock IsVisible="{Binding IsEmptyVisible}"
                   Text="{DynamicResource Preview.Empty}"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   Opacity="0.45"
                   TextAlignment="Center"
                   Margin="16" />

        <!-- Loading: debounce passed, fetching bytes -->
        <StackPanel IsVisible="{Binding IsLoadingVisible}"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Spacing="10">
            <ProgressBar IsIndeterminate="True" Width="120" />
            <TextBlock Text="{DynamicResource Preview.Loading}"
                       HorizontalAlignment="Center"
                       Opacity="0.6" />
        </StackPanel>

        <!-- Binary / Encrypted / Error: show StatusMessage centred -->
        <TextBlock IsVisible="{Binding IsStatusVisible}"
                   Text="{Binding StatusMessage}"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   TextAlignment="Center"
                   TextWrapping="Wrap"
                   Margin="16" />

        <!-- Text / Code / Markdown -->
        <ScrollViewer x:Name="TextScrollViewer"
                      IsVisible="{Binding IsTextVisible}"
                      HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Auto">
            <TextBlock FontFamily="Courier New, Cascadia Code, Consolas, monospace"
                       FontSize="12"
                       Text="{Binding PreviewText}"
                       TextWrapping="NoWrap"
                       Margin="8" />
        </ScrollViewer>

    </Panel>

</UserControl>
