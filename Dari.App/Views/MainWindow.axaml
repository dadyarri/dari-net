<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Dari.App.ViewModels"
        xmlns:views="using:Dari.App.Views"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        x:Class="Dari.App.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/dari.ico"
        Title="{Binding Title}"
        Width="1024"
        Height="680"
        MinWidth="640"
        MinHeight="480"
        DragDrop.AllowDrop="True">

    <Window.KeyBindings>
        <KeyBinding Gesture="Ctrl+N" Command="{Binding NewArchiveCommand}" />
        <KeyBinding Gesture="Ctrl+O" Command="{Binding OpenArchiveCommand}" />
        <KeyBinding Gesture="Ctrl+W" Command="{Binding CloseArchiveCommand}" />
        <KeyBinding Gesture="Ctrl+E" Command="{Binding Browser.ExtractAllCommand}" />
        <KeyBinding Gesture="Ctrl+Shift+A" Command="{Binding AppendFilesCommand}" />
    </Window.KeyBindings>

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- Menu bar -->
        <Menu Grid.Row="0">
            <MenuItem Header="{DynamicResource Menu.File}">
                <MenuItem Header="{DynamicResource Menu.File.NewArchive}"
                          InputGesture="Ctrl+N"
                          Command="{Binding NewArchiveCommand}" />
                <MenuItem Header="{DynamicResource Menu.File.Open}"
                          InputGesture="Ctrl+O"
                          Command="{Binding OpenArchiveCommand}" />
                <MenuItem Header="{DynamicResource Menu.File.Close}"
                          InputGesture="Ctrl+W"
                          Command="{Binding CloseArchiveCommand}" />
                <Separator />
                <MenuItem Header="{DynamicResource Menu.File.Exit}"
                          Command="{Binding ExitCommand}" />
            </MenuItem>
            <MenuItem Header="{DynamicResource Menu.Archive}"
                      IsEnabled="{Binding Browser, Converter={x:Static ObjectConverters.IsNotNull}}">
                <MenuItem Header="{DynamicResource Menu.Archive.ExtractAll}"
                          InputGesture="Ctrl+E"
                          Command="{Binding Browser.ExtractAllCommand}" />
                <MenuItem Header="{DynamicResource Menu.Archive.ExtractSelected}"
                          Command="{Binding Browser.ExtractSelectedCommand}" />
                <Separator />
                <MenuItem Header="{DynamicResource Menu.Archive.AppendFiles}"
                          InputGesture="Ctrl+Shift+A"
                          Command="{Binding AppendFilesCommand}" />
            </MenuItem>
            <MenuItem Header="{DynamicResource Menu.Help}">
                <MenuItem Header="{DynamicResource Menu.Help.Settings}"
                          Command="{Binding SettingsCommand}" />
                <MenuItem Header="{DynamicResource Menu.Help.About}"
                          Command="{Binding AboutCommand}" />
            </MenuItem>
        </Menu>

        <!-- Main content area -->
        <Panel Grid.Row="1">

            <!-- Placeholder shown when no archive is open -->
            <TextBlock Text="{DynamicResource MainWindow.Placeholder}"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Opacity="0.5"
                       FontSize="16"
                       IsVisible="{Binding Browser, Converter={x:Static ObjectConverters.IsNull}}" />

            <!-- Archive browser (visible when an archive is open) -->
            <ContentControl Content="{Binding Browser}"
                            HorizontalContentAlignment="Stretch"
                            VerticalContentAlignment="Stretch">
                <ContentControl.DataTemplates>
                    <DataTemplate DataType="{x:Type vm:ArchiveBrowserViewModel}">
                        <views:ArchiveBrowserView HorizontalAlignment="Stretch"
                                                  VerticalAlignment="Stretch" />
                    </DataTemplate>
                </ContentControl.DataTemplates>
            </ContentControl>

        </Panel>

        <!-- Status bar -->
        <Border Grid.Row="2"
                BorderThickness="0,1,0,0"
                Padding="8,4">
            <DockPanel>

                <!-- Right side: preview pane status (type label • truncation notice) -->
                <StackPanel DockPanel.Dock="Right"
                            Orientation="Horizontal"
                            IsVisible="{Binding Browser.Preview.IsBottomStatusVisible}">
                    <views:StatusBarWidget Label="{Binding Browser.Preview.PreviewTypeName}"
                                          Value="{Binding Browser.Preview.PreviewTypeEncoding}" />
                    <views:StatusBarWidget IsVisible="{Binding Browser.Preview.IsTruncationVisible}"
                                          ShowBulletBefore="True"
                                          Label="{DynamicResource Preview.Truncated.Label}"
                                          Value="{Binding Browser.Preview.TruncationDisplay}" />
                </StackPanel>

                <!-- Left side: archive status text • total size • compressed size -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <!-- No archive open: plain status (Ready / Error / Done) -->
                    <TextBlock Text="{Binding StatusText}"
                               IsVisible="{Binding Browser, Converter={x:Static ObjectConverters.IsNull}}"
                               FontSize="11"
                               Opacity="0.7"
                               VerticalAlignment="Center" />
                    <!-- Archive open: all widgets via StatusBarWidget -->
                    <StackPanel Orientation="Horizontal"
                                IsVisible="{Binding Browser, Converter={x:Static ObjectConverters.IsNotNull}}">
                        <views:StatusBarWidget Label="{DynamicResource Status.Opened.Label}"
                                              Value="{Binding Browser.FileCount}" />
                        <views:StatusBarWidget ShowBulletBefore="True"
                                              Label="{DynamicResource Archive.TotalSize}"
                                              Value="{Binding Browser.TotalSizeDisplay}" />
                        <views:StatusBarWidget ShowBulletBefore="True"
                                              Label="{DynamicResource Archive.Compressed}"
                                              Value="{Binding Browser.TotalCompressedSizeDisplay}" />
                    </StackPanel>
                </StackPanel>

            </DockPanel>
        </Border>

    </Grid>

</Window>

