<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Dari.App.ViewModels"
             xmlns:models="using:Dari.App.Models"
             xmlns:dgrid="clr-namespace:Avalonia.Controls;assembly=Avalonia.Controls.DataGrid"
             x:Class="Dari.App.Views.ArchiveBrowserView"
             x:DataType="vm:ArchiveBrowserViewModel">

    <Grid RowDefinitions="Auto,Auto,*">

        <!-- Archive header metadata -->
        <Border Grid.Row="0"
                Padding="12,8"
                BorderThickness="0,0,0,1">
            <WrapPanel Orientation="Horizontal">
                <StackPanel Orientation="Horizontal" Margin="0,0,20,0">
                    <TextBlock Text="{DynamicResource Archive.Created}" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding CreatedAt, StringFormat='{}{0:yyyy-MM-dd HH:mm}'}" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,20,0">
                    <TextBlock Text="{DynamicResource Archive.Files}" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding FileCount}" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,20,0">
                    <TextBlock Text="{DynamicResource Archive.TotalSize}" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding TotalSizeDisplay}" />
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="{DynamicResource Archive.Compressed}" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding TotalCompressedSizeDisplay}" />
                </StackPanel>
            </WrapPanel>
        </Border>

        <!-- Toolbar: search + view-mode toggle + sort buttons + extract buttons -->
        <Grid Grid.Row="1"
              ColumnDefinitions="*,Auto,Auto,Auto,Auto,Auto,Auto,Auto"
              Margin="8,4"
              VerticalAlignment="Center">

            <TextBox Grid.Column="0"
                     Text="{Binding SearchText}"
                     Watermark="{DynamicResource Watermark.Search}"
                     Margin="0,0,8,0" />

            <Button Grid.Column="1"
                    Content="{Binding ViewModeDisplay}"
                    Command="{Binding ToggleViewModeCommand}"
                    ToolTip.Tip="{DynamicResource Tooltip.ToggleView}"
                    Margin="0,0,8,0" />

            <TextBlock Grid.Column="2"
                       Text="{DynamicResource Toolbar.Sort}"
                       VerticalAlignment="Center"
                       Margin="0,0,4,0" />

            <Button Grid.Column="3"
                    Content="{DynamicResource Toolbar.SortName}"
                    Command="{Binding SortByCommand}"
                    CommandParameter="Name"
                    Margin="0,0,4,0" />
            <Button Grid.Column="4"
                    Content="{DynamicResource Toolbar.SortSize}"
                    Command="{Binding SortByCommand}"
                    CommandParameter="Size"
                    Margin="0,0,4,0" />
            <Button Grid.Column="5"
                    Content="{DynamicResource Toolbar.SortDate}"
                    Command="{Binding SortByCommand}"
                    CommandParameter="Date"
                    Margin="0,0,16,0" />

            <!-- Extraction buttons -->
            <Button Grid.Column="6"
                    Content="{DynamicResource Button.ExtractSelected}"
                    Command="{Binding ExtractSelectedCommand}"
                    ToolTip.Tip="{DynamicResource Tooltip.ExtractSelected}"
                    Margin="0,0,4,0" />
            <Button Grid.Column="7"
                    Content="{DynamicResource Button.ExtractAll}"
                    Classes="accent"
                    Command="{Binding ExtractAllCommand}"
                    ToolTip.Tip="{DynamicResource Tooltip.ExtractAll}"
                    Margin="0,0,0,0" />

        </Grid>

        <!-- Main content: flat DataGrid or tree TreeView -->
        <Panel Grid.Row="2">

            <!-- Flat list -->
            <dgrid:DataGrid x:Name="FlatGrid"
                      ItemsSource="{Binding FilteredEntries}"
                      IsVisible="{Binding ViewMode, Converter={x:Static ObjectConverters.Equal}, ConverterParameter={x:Static vm:ViewMode.Flat}}"
                      AutoGenerateColumns="False"
                      IsReadOnly="False"
                      CanUserReorderColumns="True"
                      CanUserResizeColumns="True"
                      CanUserSortColumns="False"
                      GridLinesVisibility="Horizontal"
                      SelectionMode="Extended">
                <dgrid:DataGrid.Columns>
                    <dgrid:DataGridCheckBoxColumn Width="36"
                                            Binding="{Binding IsSelected}"
                                            IsReadOnly="False">
                        <dgrid:DataGridCheckBoxColumn.Header>
                            <TextBlock Text="{DynamicResource Column.Select}" />
                        </dgrid:DataGridCheckBoxColumn.Header>
                    </dgrid:DataGridCheckBoxColumn>
                    <dgrid:DataGridTextColumn Binding="{Binding Name}"
                                        Width="*">
                        <dgrid:DataGridTextColumn.Header>
                            <TextBlock Text="{DynamicResource Column.Name}" />
                        </dgrid:DataGridTextColumn.Header>
                    </dgrid:DataGridTextColumn>
                    <dgrid:DataGridTextColumn Binding="{Binding Path}"
                                        Width="2*">
                        <dgrid:DataGridTextColumn.Header>
                            <TextBlock Text="{DynamicResource Column.Path}" />
                        </dgrid:DataGridTextColumn.Header>
                    </dgrid:DataGridTextColumn>
                    <dgrid:DataGridTextColumn Binding="{Binding OriginalSizeDisplay}"
                                        Width="80">
                        <dgrid:DataGridTextColumn.Header>
                            <TextBlock Text="{DynamicResource Column.Size}" />
                        </dgrid:DataGridTextColumn.Header>
                    </dgrid:DataGridTextColumn>
                    <dgrid:DataGridTextColumn Binding="{Binding CompressedSizeDisplay}"
                                        Width="90">
                        <dgrid:DataGridTextColumn.Header>
                            <TextBlock Text="{DynamicResource Column.Compressed}" />
                        </dgrid:DataGridTextColumn.Header>
                    </dgrid:DataGridTextColumn>
                    <dgrid:DataGridTextColumn Binding="{Binding CompressionRatioDisplay}"
                                        Width="70">
                        <dgrid:DataGridTextColumn.Header>
                            <TextBlock Text="{DynamicResource Column.Ratio}" />
                        </dgrid:DataGridTextColumn.Header>
                    </dgrid:DataGridTextColumn>
                    <dgrid:DataGridTextColumn Binding="{Binding Algorithm}"
                                        Width="90">
                        <dgrid:DataGridTextColumn.Header>
                            <TextBlock Text="{DynamicResource Column.Algorithm}" />
                        </dgrid:DataGridTextColumn.Header>
                    </dgrid:DataGridTextColumn>
                    <dgrid:DataGridTextColumn Binding="{Binding ModifiedAtDisplay}"
                                        Width="130">
                        <dgrid:DataGridTextColumn.Header>
                            <TextBlock Text="{DynamicResource Column.Date}" />
                        </dgrid:DataGridTextColumn.Header>
                    </dgrid:DataGridTextColumn>
                    <dgrid:DataGridTextColumn Binding="{Binding PermissionsDisplay}"
                                        Width="90">
                        <dgrid:DataGridTextColumn.Header>
                            <TextBlock Text="{DynamicResource Column.Permissions}" />
                        </dgrid:DataGridTextColumn.Header>
                    </dgrid:DataGridTextColumn>
                </dgrid:DataGrid.Columns>
            </dgrid:DataGrid>

            <!-- Tree view -->
            <TreeView x:Name="TreeViewControl"
                      ItemsSource="{Binding TreeRootNodes}"
                      IsVisible="{Binding ViewMode, Converter={x:Static ObjectConverters.Equal}, ConverterParameter={x:Static vm:ViewMode.Tree}}">
                <TreeView.DataTemplates>
                    <TreeDataTemplate DataType="{x:Type vm:DirectoryNodeViewModel}"
                                      ItemsSource="{Binding Children}">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <CheckBox IsChecked="{Binding IsSelected}"
                                      VerticalAlignment="Center" />
                            <TextBlock Text="{Binding Name}"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </TreeDataTemplate>
                    <DataTemplate DataType="{x:Type vm:FileNodeViewModel}">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <CheckBox IsChecked="{Binding Entry.IsSelected}"
                                      VerticalAlignment="Center" />
                            <TextBlock Text="{Binding Entry.Name}"
                                       VerticalAlignment="Center" />
                            <TextBlock Text="{Binding Entry.OriginalSizeDisplay}"
                                       Opacity="0.6"
                                       FontSize="11"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </DataTemplate>
                </TreeView.DataTemplates>
            </TreeView>

        </Panel>

    </Grid>

</UserControl>

