<?xml version="1.0" encoding="UTF-8"?>
<mime-info xmlns="http://www.freedesktop.org/standards/shared-mime-info">
  <mime-type type="application/x-dari-archive">
    <comment>Dari Archive</comment>
    <comment xml:lang="ru">Архив Dari</comment>
    <glob pattern="*.dar"/>
    <magic priority="60">
      <match type="string" offset="0" value="DARI"/>
    </magic>
    <icon name="dari"/>
  </mime-type>
</mime-info>
