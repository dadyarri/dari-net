<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Dari.App.ViewModels"
        xmlns:services="using:Dari.App.Services"
        x:Class="Dari.App.Views.SettingsView"
        x:DataType="vm:SettingsViewModel"
        Title="{DynamicResource Settings.Title}"
        Width="460"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        ShowInTaskbar="False">

    <Grid Margin="20" RowDefinitions="*,Auto">

        <StackPanel Grid.Row="0" Spacing="12">

            <!-- Language -->
            <StackPanel Spacing="4">
                <TextBlock Text="{DynamicResource Settings.Language}" />
                <ComboBox ItemsSource="{Binding AvailableLanguages}"
                          SelectedItem="{Binding SelectedLanguage}"
                          HorizontalAlignment="Stretch">
                    <ComboBox.ItemTemplate>
                        <DataTemplate DataType="{x:Type services:LanguageItem}">
                            <TextBlock Text="{Binding DisplayName}" />
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
            </StackPanel>

            <!-- Theme -->
            <StackPanel Spacing="4">
                <TextBlock Text="{DynamicResource Settings.Theme}" />
                <ComboBox ItemsSource="{Binding AvailableThemes}"
                          SelectedItem="{Binding SelectedTheme}"
                          HorizontalAlignment="Stretch">
                    <ComboBox.ItemTemplate>
                        <DataTemplate DataType="{x:Type services:ThemeItem}">
                            <TextBlock Text="{Binding DisplayName}" />
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
            </StackPanel>

            <!-- Preview size limit -->
            <StackPanel Spacing="4">
                <TextBlock Text="{DynamicResource Settings.PreviewMaxBytes}" />
                <NumericUpDown Value="{Binding PreviewMaxMb}"
                               Minimum="1"
                               Maximum="512"
                               FormatString="0 MB"
                               HorizontalAlignment="Stretch" />
            </StackPanel>

            <!-- Preview font family -->
            <StackPanel Spacing="4">
                <TextBlock Text="{DynamicResource Settings.PreviewFontFamily}" />
                <CheckBox Content="{DynamicResource Settings.PreviewFontShowAll}"
                          IsChecked="{Binding ShowAllPreviewFonts}" />
                <ComboBox ItemsSource="{Binding AvailablePreviewFonts}"
                          SelectedItem="{Binding SelectedPreviewFont}"
                          HorizontalAlignment="Stretch">
                    <ComboBox.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:PreviewFontItem}">
                            <Grid ColumnDefinitions="*,Auto">
                                <TextBlock Grid.Column="0"
                                           Text="{Binding FamilyName}"
                                           FontFamily="{Binding FontFamily}"
                                           TextTrimming="CharacterEllipsis" />
                                <TextBlock Grid.Column="1"
                                           Text="{Binding PreviewSample}"
                                           FontFamily="{Binding FontFamily}"
                                           TextAlignment="Right"
                                           Margin="8,0,0,0" />
                            </Grid>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
            </StackPanel>

            <!-- Preview font size -->
            <StackPanel Spacing="4">
                <TextBlock Text="{DynamicResource Settings.PreviewFontSize}" />
                <NumericUpDown Value="{Binding PreviewFontSize}"
                               Minimum="8"
                               Maximum="48"
                               FormatString="0"
                               HorizontalAlignment="Stretch" />
            </StackPanel>

        </StackPanel>

        <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Spacing="8"
                    Margin="0,16,0,0">
            <Button Content="{DynamicResource Button.Cancel}"
                    Command="{Binding CancelCommand}" />
            <Button Content="{DynamicResource Button.Save}"
                    Classes="accent"
                    Command="{Binding SaveCommand}" />
        </StackPanel>

    </Grid>

</Window>
