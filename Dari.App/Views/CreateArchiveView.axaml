<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Dari.App.ViewModels"
        x:Class="Dari.App.Views.CreateArchiveView"
        x:DataType="vm:CreateArchiveViewModel"
        Title="{DynamicResource Wizard.Title}"
        Width="520"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        ShowInTaskbar="False">

    <Grid Margin="20" RowDefinitions="*,Auto">

        <!-- ================================================================
             Step 1 — Source
             ================================================================ -->
        <StackPanel Grid.Row="0" Spacing="10" IsVisible="{Binding IsStep1}">

            <TextBlock Text="{DynamicResource Wizard.Step1.Title}" FontWeight="SemiBold" FontSize="14" />

            <TextBlock Text="{DynamicResource Wizard.Step1.Subtitle}"
                       TextWrapping="Wrap"
                       Opacity="0.7" />

            <!-- Directory picker -->
            <Grid ColumnDefinitions="*,Auto">
                <TextBox Grid.Column="0"
                         Margin="0,0,6,0"
                         Text="{Binding SourcePath}"
                         Watermark="{DynamicResource Watermark.SourceDirectory}"
                         IsReadOnly="True" />
                <Button Grid.Column="1"
                        Content="{DynamicResource Button.BrowseDirectory}"
                        Command="{Binding BrowseSourceDirectoryCommand}" />
            </Grid>

            <!-- Individual file picker -->
            <Button Content="{DynamicResource Button.BrowseFiles}"
                    Command="{Binding BrowseSourceFilesCommand}"
                    HorizontalAlignment="Left" />

            <!-- File preview -->
            <StackPanel Spacing="4"
                        IsVisible="{Binding HasSourcePath}">
                <TextBlock Text="{DynamicResource Wizard.Step1.FilesLabel}"
                           Opacity="0.7"
                           FontSize="11" />
                <ListBox ItemsSource="{Binding PreviewFiles}"
                         MaxHeight="180"
                         FontFamily="Monospace"
                         FontSize="11" />
                <StackPanel Orientation="Horizontal" Spacing="4">
                    <TextBlock Text="{Binding PreviewFiles.Count}" Opacity="0.6" FontSize="11" />
                    <TextBlock Text="{DynamicResource Wizard.Step1.FileCount}" Opacity="0.6" FontSize="11" />
                </StackPanel>
            </StackPanel>

        </StackPanel>

        <!-- ================================================================
             Step 2 — Options
             ================================================================ -->
        <StackPanel Grid.Row="0" Spacing="12" IsVisible="{Binding IsStep2}">

            <TextBlock Text="{DynamicResource Wizard.Step2.Title}" FontWeight="SemiBold" FontSize="14" />

            <!-- Compression -->
            <StackPanel Spacing="4">
                <TextBlock Text="{DynamicResource Wizard.Step2.CompressionLabel}" />
                <ComboBox ItemsSource="{Binding CompressionOptions}"
                          SelectedItem="{Binding SelectedCompression}"
                          HorizontalAlignment="Stretch" />
            </StackPanel>

            <!-- Deduplication -->
            <CheckBox IsChecked="{Binding EnableDeduplication}"
                      Content="{DynamicResource Wizard.Step2.Deduplication}" />

            <!-- Encryption -->
            <CheckBox IsChecked="{Binding EnableEncryption}"
                      Content="{DynamicResource Wizard.Step2.Encryption}" />

            <StackPanel Spacing="6" IsVisible="{Binding ShowEncryptionFields}">
                <TextBox PasswordChar="•"
                         Text="{Binding EncryptionPassphrase}"
                         Watermark="{DynamicResource Watermark.Passphrase}" />
                <TextBox PasswordChar="•"
                         Text="{Binding EncryptionPassphraseConfirm}"
                         Watermark="{DynamicResource Watermark.ConfirmPassphrase}" />
            </StackPanel>

            <!-- Validation error -->
            <TextBlock Text="{Binding OptionsError}"
                       Foreground="Red"
                       TextWrapping="Wrap"
                       IsVisible="{Binding OptionsError, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />

        </StackPanel>

        <!-- ================================================================
             Step 3 — Destination + progress
             ================================================================ -->
        <StackPanel Grid.Row="0" Spacing="10" IsVisible="{Binding IsStep3}">

            <TextBlock Text="{DynamicResource Wizard.Step3.Title}" FontWeight="SemiBold" FontSize="14" />

            <!-- Output path (shown before creation starts) -->
            <StackPanel Spacing="6"
                        IsVisible="{Binding !IsCreating}">
                <TextBlock IsVisible="{Binding !IsCompleted}"
                           Text="{DynamicResource Wizard.Step3.Subtitle}" Opacity="0.7" />
                <Grid ColumnDefinitions="*,Auto"
                      IsVisible="{Binding !IsCompleted}">
                    <TextBox Grid.Column="0"
                             Margin="0,0,6,0"
                             Text="{Binding OutputPath}"
                             Watermark="{DynamicResource Watermark.OutputPath}"
                             IsReadOnly="True" />
                    <Button Grid.Column="1"
                            Content="{DynamicResource Button.Browse}"
                            Command="{Binding BrowseOutputCommand}" />
                </Grid>
            </StackPanel>

            <!-- In-progress panel -->
            <StackPanel Spacing="8" IsVisible="{Binding IsCreating}">
                <TextBlock Text="{DynamicResource Wizard.Step3.Creating}" FontWeight="SemiBold" />

                <ProgressBar Minimum="0"
                             Maximum="1"
                             Value="{Binding Progress}"
                             Height="12" />

                <Grid ColumnDefinitions="*,Auto">
                    <TextBlock Grid.Column="0"
                               Text="{Binding CurrentFile}"
                               TextTrimming="CharacterEllipsis"
                               Opacity="0.7"
                               FontSize="11" />
                    <TextBlock Grid.Column="1"
                               Margin="8,0,0,0"
                               FontSize="11"
                               Opacity="0.7">
                        <Run Text="{Binding DoneCount}" />
                        <Run Text="/" />
                        <Run Text="{Binding TotalCount}" />
                    </TextBlock>
                </Grid>
            </StackPanel>

            <!-- Completion panel -->
            <StackPanel Spacing="6" IsVisible="{Binding IsCompleted}">
                <TextBlock Text="{Binding StatusMessage}"
                           TextWrapping="Wrap"
                           FontWeight="SemiBold" />
                <TextBlock Text="{Binding OutputPath}"
                           FontFamily="Monospace"
                           TextWrapping="Wrap"
                           FontSize="11"
                           Opacity="0.8" />
            </StackPanel>

        </StackPanel>

        <!-- ================================================================
             Navigation buttons (bottom row)
             ================================================================ -->
        <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Spacing="8"
                    Margin="0,16,0,0">

            <!-- Back (steps 2 and 3 pre-creation) -->
            <Button Content="{DynamicResource Button.Back}"
                    Command="{Binding PreviousStepCommand}"
                    IsVisible="{Binding IsStep2}" />
            <Button Content="{DynamicResource Button.Back}"
                    Command="{Binding PreviousStepCommand}"
                    IsVisible="{Binding IsReadyToCreate}" />

            <!-- Next (steps 1 and 2) -->
            <Button Content="{DynamicResource Button.Next}"
                    Classes="accent"
                    Command="{Binding NextStepCommand}"
                    IsVisible="{Binding IsStep1}" />
            <Button Content="{DynamicResource Button.Next}"
                    Classes="accent"
                    Command="{Binding NextStepCommand}"
                    IsVisible="{Binding IsStep2}" />

            <!-- Create (step 3, before creation starts) -->
            <Button Content="{DynamicResource Button.Create}"
                    Classes="accent"
                    Command="{Binding CreateCommand}"
                    IsVisible="{Binding IsReadyToCreate}" />

            <!-- Cancel (while creating) -->
            <Button Content="{DynamicResource Button.Cancel}"
                    Command="{Binding CancelCommand}"
                    IsVisible="{Binding IsCreating}" />

            <!-- Post-completion buttons -->
            <Button Content="{DynamicResource Button.OpenInExplorer}"
                    Command="{Binding OpenInExplorerCommand}"
                    IsVisible="{Binding IsCompleted}" />
            <Button Content="{DynamicResource Button.Close}"
                    Classes="accent"
                    Command="{Binding CloseWizardCommand}"
                    IsVisible="{Binding IsCompleted}" />

            <!-- Cancel on step 1/2 (dismiss without creating) -->
            <Button Content="{DynamicResource Button.Cancel}"
                    Command="{Binding CancelCommand}"
                    IsVisible="{Binding IsStep1}" />
            <Button Content="{DynamicResource Button.Cancel}"
                    Command="{Binding CancelCommand}"
                    IsVisible="{Binding IsStep2}" />

        </StackPanel>

    </Grid>

</Window>
