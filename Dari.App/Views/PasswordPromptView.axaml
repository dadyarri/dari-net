<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Dari.App.ViewModels"
        x:Class="Dari.App.Views.PasswordPromptView"
        x:DataType="vm:PasswordPromptViewModel"
        Title="{DynamicResource Password.Title}"
        Width="360"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        ShowInTaskbar="False">

    <Grid RowDefinitions="*,Auto" Margin="20">

        <StackPanel Grid.Row="0" Spacing="8" VerticalAlignment="Center">
            <TextBlock Text="{DynamicResource Password.Prompt}"
                       TextWrapping="Wrap"
                       IsVisible="{Binding IsEncryptionSupported}" />
            <TextBlock Text="{DynamicResource Password.EncryptionUnsupported}"
                       TextWrapping="Wrap"
                       Foreground="OrangeRed"
                       IsVisible="{Binding !IsEncryptionSupported}" />
            <TextBox x:Name="PassphraseBox"
                     PasswordChar="•"
                     Text="{Binding Passphrase}"
                     Watermark="{DynamicResource Watermark.Passphrase}"
                     IsEnabled="{Binding IsEncryptionSupported}" />
            <TextBlock Text="{Binding ErrorMessage}"
                       Foreground="Red"
                       TextWrapping="Wrap"
                       IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
        </StackPanel>

        <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Spacing="8"
                    Margin="0,12,0,0">
            <Button Content="{DynamicResource Button.Cancel}"
                    Command="{Binding CancelCommand}" />
            <Button Content="{DynamicResource Button.OK}"
                    Classes="accent"
                    Command="{Binding ConfirmCommand}"
                    IsDefault="True"
                    IsEnabled="{Binding IsEncryptionSupported}" />
        </StackPanel>

    </Grid>

</Window>
