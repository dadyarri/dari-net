<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Dari.App.ViewModels"
        x:Class="Dari.App.Views.NameConflictView"
        x:DataType="vm:NameConflictViewModel"
        Title="{DynamicResource Conflict.Title}"
        Width="480"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        ShowInTaskbar="False">

    <Grid RowDefinitions="*,Auto" Margin="20">

        <StackPanel Grid.Row="0" Spacing="8" VerticalAlignment="Center">
            <TextBlock Text="{DynamicResource Conflict.Prompt}"
                       TextWrapping="Wrap" />
            <TextBlock Text="{Binding ExistingPath}"
                       FontFamily="Monospace"
                       TextWrapping="Wrap"
                       Opacity="0.8" />
            <TextBlock Text="{DynamicResource Conflict.Question}"
                       Margin="0,4,0,0" />
        </StackPanel>

        <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Spacing="8"
                    Margin="0,16,0,0">
            <Button Content="{DynamicResource Button.Skip}"
                    Command="{Binding SkipCommand}" />
            <Button Content="{DynamicResource Button.Rename}"
                    Command="{Binding RenameCommand}" />
            <Button Content="{DynamicResource Button.Overwrite}"
                    Classes="accent"
                    Command="{Binding OverwriteCommand}" />
        </StackPanel>

    </Grid>

</Window>
