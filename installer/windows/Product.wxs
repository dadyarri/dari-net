<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">

  <!-- Product definition -->
  <Package Name="Dari"
           Manufacturer="dadyarri"
           Version="!(bind.FileVersion.DariExe)"
           UpgradeCode="F4A8E9C1-3B2D-4E6F-A1C7-9D8B5E0F2A3C"
           Scope="perUser">

    <MajorUpgrade DowngradeErrorMessage="A newer version of Dari is already installed." />

    <MediaTemplate EmbedCab="yes" />

    <!-- Installation directory structure -->
    <StandardDirectory Id="LocalAppDataFolder">
      <Directory Id="INSTALLFOLDER" Name="Dari">
        <Directory Id="AppDir" Name="app" />
      </Directory>
    </StandardDirectory>

    <!-- Application files component group (populated by heat / harvesting) -->
    <ComponentGroup Id="ProductComponents" Directory="AppDir">
      <Component Id="DariExeComponent">
        <File Id="DariExe" Source="$(var.PublishDir)\Dari.App.exe" KeyPath="yes">
          <Shortcut Id="StartMenuShortcut"
                    Name="Dari"
                    Directory="ProgramMenuFolder"
                    Advertise="yes"
                    Icon="DariIcon"
                    IconIndex="0"
                    WorkingDirectory="AppDir" />
        </File>
      </Component>
    </ComponentGroup>

    <Feature Id="ProductFeature" Title="Dari" Level="1">
      <ComponentGroupRef Id="ProductComponents" />
      <ComponentRef Id="DarFileAssociation" />
      <ComponentRef Id="ShellContextMenu" />
    </Feature>

    <Icon Id="DariIcon" SourceFile="$(var.PublishDir)\Dari.App.exe" />

    <!-- File association for .dar -->
    <StandardDirectory Id="LocalAppDataFolder">
      <Directory Id="AssocDir" Name="Dari">
        <Component Id="DarFileAssociation" Guid="A1B2C3D4-E5F6-7890-ABCD-EF1234567890">
          <RegistryValue Root="HKCU"
                         Key="Software\Classes\.dar"
                         Value="Dari.DarArchive"
                         Type="string"
                         KeyPath="yes" />
          <RegistryValue Root="HKCU"
                         Key="Software\Classes\.dar"
                         Name="Content Type"
                         Value="application/x-dari-archive"
                         Type="string" />
          <RegistryValue Root="HKCU"
                         Key="Software\Classes\Dari.DarArchive"
                         Value="Dari Archive"
                         Type="string" />
          <RegistryValue Root="HKCU"
                         Key="Software\Classes\Dari.DarArchive\DefaultIcon"
                         Value="[AppDir]Dari.App.exe,0"
                         Type="string" />
          <RegistryValue Root="HKCU"
                         Key="Software\Classes\Dari.DarArchive\shell\open\command"
                         Value="&quot;[AppDir]Dari.App.exe&quot; &quot;%1&quot;"
                         Type="string" />
        </Component>

        <!-- Explorer context menu -->
        <Component Id="ShellContextMenu" Guid="B2C3D4E5-F6A7-8901-BCDE-F12345678901">
          <RegistryValue Root="HKCU"
                         Key="Software\Classes\.dar\shell\dari_open"
                         Value="Open with Dari"
                         Type="string"
                         KeyPath="yes" />
          <RegistryValue Root="HKCU"
                         Key="Software\Classes\.dar\shell\dari_open\command"
                         Value="&quot;[AppDir]Dari.App.exe&quot; &quot;%1&quot;"
                         Type="string" />
          <RegistryValue Root="HKCU"
                         Key="Software\Classes\.dar\shell\dari_extract"
                         Value="Extract here (Dari)"
                         Type="string" />
          <RegistryValue Root="HKCU"
                         Key="Software\Classes\.dar\shell\dari_extract\command"
                         Value="&quot;[AppDir]Dari.App.exe&quot; --extract-here &quot;%1&quot;"
                         Type="string" />
        </Component>
      </Directory>
    </StandardDirectory>

  </Package>
</Wix>
