<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Dari.App.ViewModels"
        x:Class="Dari.App.Views.PasswordPromptView"
        x:DataType="vm:PasswordPromptViewModel"
        Title="Enter Passphrase"
        Width="360"
        Height="180"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        ShowInTaskbar="False">

    <Grid RowDefinitions="*,Auto" Margin="20">

        <StackPanel Grid.Row="0" Spacing="8" VerticalAlignment="Center">
            <TextBlock Text="This archive is encrypted. Enter the passphrase to continue."
                       TextWrapping="Wrap" />
            <TextBox x:Name="PassphraseBox"
                     PasswordChar="•"
                     Text="{Binding Passphrase}"
                     Watermark="Passphrase" />
        </StackPanel>

        <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Spacing="8">
            <Button Content="Cancel"
                    Command="{Binding CancelCommand}" />
            <Button Content="OK"
                    Classes="accent"
                    Command="{Binding ConfirmCommand}"
                    IsDefault="True" />
        </StackPanel>

    </Grid>

</Window>
