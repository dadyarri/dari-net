<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Dari.App.ViewModels"
             xmlns:models="using:Dari.App.Models"
             xmlns:dgrid="clr-namespace:Avalonia.Controls;assembly=Avalonia.Controls.DataGrid"
             x:Class="Dari.App.Views.ArchiveBrowserView"
             x:DataType="vm:ArchiveBrowserViewModel">

    <Grid RowDefinitions="Auto,Auto,*">

        <!-- Archive header metadata -->
        <Border Grid.Row="0"
                Padding="12,8"
                BorderThickness="0,0,0,1">
            <WrapPanel Orientation="Horizontal">
                <TextBlock Margin="0,0,20,0">
                    <Run Text="Created: " FontWeight="SemiBold"/>
                    <Run Text="{Binding CreatedAt, StringFormat='{}{0:yyyy-MM-dd HH:mm}'}" />
                </TextBlock>
                <TextBlock Margin="0,0,20,0">
                    <Run Text="Files: " FontWeight="SemiBold"/>
                    <Run Text="{Binding FileCount}" />
                </TextBlock>
                <TextBlock Margin="0,0,20,0">
                    <Run Text="Total size: " FontWeight="SemiBold"/>
                    <Run Text="{Binding TotalSizeDisplay}" />
                </TextBlock>
                <TextBlock>
                    <Run Text="Compressed: " FontWeight="SemiBold"/>
                    <Run Text="{Binding TotalCompressedSizeDisplay}" />
                </TextBlock>
            </WrapPanel>
        </Border>

        <!-- Toolbar: search + view-mode toggle + sort buttons + extract buttons -->
        <Grid Grid.Row="1"
              ColumnDefinitions="*,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto"
              Margin="8,4"
              VerticalAlignment="Center">

            <TextBox Grid.Column="0"
                     Text="{Binding SearchText}"
                     Watermark="Search…"
                     Margin="0,0,8,0" />

            <Button Grid.Column="1"
                    Content="{Binding ViewMode}"
                    Command="{Binding ToggleViewModeCommand}"
                    ToolTip.Tip="Toggle flat/tree view"
                    Margin="0,0,8,0" />

            <TextBlock Grid.Column="2"
                       Text="Sort:"
                       VerticalAlignment="Center"
                       Margin="0,0,4,0" />

            <Button Grid.Column="3"
                    Content="Name"
                    Command="{Binding SortByCommand}"
                    CommandParameter="Name"
                    Margin="0,0,4,0" />
            <Button Grid.Column="4"
                    Content="Size"
                    Command="{Binding SortByCommand}"
                    CommandParameter="Size"
                    Margin="0,0,4,0" />
            <Button Grid.Column="5"
                    Content="Date"
                    Command="{Binding SortByCommand}"
                    CommandParameter="Date"
                    Margin="0,0,16,0" />

            <!-- Extraction buttons -->
            <Button Grid.Column="6"
                    Content="Extract Selected"
                    Command="{Binding ExtractSelectedCommand}"
                    ToolTip.Tip="Extract checked entries to a folder"
                    Margin="0,0,4,0" />
            <Button Grid.Column="7"
                    Content="Extract All"
                    Classes="accent"
                    Command="{Binding ExtractAllCommand}"
                    ToolTip.Tip="Extract all entries to a folder"
                    Margin="0,0,0,0" />

        </Grid>

        <!-- Main content: flat DataGrid or tree TreeView -->
        <Panel Grid.Row="2">

            <!-- Flat list -->
            <dgrid:DataGrid x:Name="FlatGrid"
                      ItemsSource="{Binding FilteredEntries}"
                      IsVisible="{Binding ViewMode, Converter={x:Static ObjectConverters.Equal}, ConverterParameter={x:Static vm:ViewMode.Flat}}"
                      AutoGenerateColumns="False"
                      IsReadOnly="False"
                      CanUserReorderColumns="True"
                      CanUserResizeColumns="True"
                      CanUserSortColumns="False"
                      GridLinesVisibility="Horizontal"
                      SelectionMode="Extended">
                <dgrid:DataGrid.Columns>
                    <dgrid:DataGridCheckBoxColumn Header="✓"
                                            Binding="{Binding IsSelected}"
                                            Width="36"
                                            IsReadOnly="False" />
                    <dgrid:DataGridTextColumn Header="Name"
                                        Binding="{Binding Name}"
                                        Width="*" />
                    <dgrid:DataGridTextColumn Header="Path"
                                        Binding="{Binding Path}"
                                        Width="2*" />
                    <dgrid:DataGridTextColumn Header="Size"
                                        Binding="{Binding OriginalSizeDisplay}"
                                        Width="80" />
                    <dgrid:DataGridTextColumn Header="Compressed"
                                        Binding="{Binding CompressedSizeDisplay}"
                                        Width="90" />
                    <dgrid:DataGridTextColumn Header="Ratio"
                                        Binding="{Binding CompressionRatioDisplay}"
                                        Width="70" />
                    <dgrid:DataGridTextColumn Header="Algorithm"
                                        Binding="{Binding Algorithm}"
                                        Width="90" />
                    <dgrid:DataGridTextColumn Header="Date"
                                        Binding="{Binding ModifiedAtDisplay}"
                                        Width="130" />
                    <dgrid:DataGridTextColumn Header="Permissions"
                                        Binding="{Binding PermissionsDisplay}"
                                        Width="90" />
                </dgrid:DataGrid.Columns>
            </dgrid:DataGrid>

            <!-- Tree view -->
            <TreeView x:Name="TreeViewControl"
                      ItemsSource="{Binding TreeRootNodes}"
                      IsVisible="{Binding ViewMode, Converter={x:Static ObjectConverters.Equal}, ConverterParameter={x:Static vm:ViewMode.Tree}}">
                <TreeView.DataTemplates>
                    <TreeDataTemplate DataType="{x:Type vm:DirectoryNodeViewModel}"
                                      ItemsSource="{Binding Children}">
                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
                    </TreeDataTemplate>
                    <DataTemplate DataType="{x:Type vm:FileNodeViewModel}">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <CheckBox IsChecked="{Binding Entry.IsSelected}"
                                      VerticalAlignment="Center" />
                            <TextBlock Text="{Binding Entry.Name}"
                                       VerticalAlignment="Center" />
                            <TextBlock Text="{Binding Entry.OriginalSizeDisplay}"
                                       Opacity="0.6"
                                       FontSize="11"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </DataTemplate>
                </TreeView.DataTemplates>
            </TreeView>

        </Panel>

    </Grid>

</UserControl>

