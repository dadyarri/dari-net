<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Dari.App.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        x:Class="Dari.App.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/dari.ico"
        Title="{Binding Title}"
        Width="1024"
        Height="680"
        MinWidth="640"
        MinHeight="480">

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- Menu bar -->
        <Menu Grid.Row="0">
            <MenuItem Header="_File">
                <MenuItem Header="_Open…"
                          InputGesture="Ctrl+O"
                          Command="{Binding OpenArchiveCommand}" />
                <MenuItem Header="_Close"
                          InputGesture="Ctrl+W"
                          Command="{Binding CloseArchiveCommand}" />
                <Separator />
                <MenuItem Header="E_xit"
                          Command="{Binding ExitCommand}" />
            </MenuItem>
            <MenuItem Header="_Help">
                <MenuItem Header="_About Dari" Command="{Binding AboutCommand}" />
            </MenuItem>
        </Menu>

        <!-- Main content area (phases B–F will fill this) -->
        <Panel Grid.Row="1">
            <TextBlock Text="Open a .dar archive to get started."
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Opacity="0.5"
                       FontSize="16" />
        </Panel>

        <!-- Status bar -->
        <Border Grid.Row="2"
                BorderThickness="0,1,0,0"
                Padding="8,4">
            <TextBlock Text="{Binding StatusText}"
                       FontSize="12"
                       Opacity="0.7" />
        </Border>

    </Grid>

</Window>
