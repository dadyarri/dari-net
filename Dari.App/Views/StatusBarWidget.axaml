<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:CompileBindings="False"
             x:Name="Root"
             x:Class="Dari.App.Views.StatusBarWidget">
    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
        <TextBlock IsVisible="{Binding ShowBulletBefore, ElementName=Root}"
                   Text=" • "
                   FontSize="11"
                   Opacity="0.45"
                   VerticalAlignment="Center" />
        <TextBlock Text="{Binding Label, ElementName=Root}"
                   FontSize="11"
                   FontWeight="SemiBold"
                   VerticalAlignment="Center" />
        <TextBlock Text="{Binding Value, ElementName=Root}"
                   FontSize="11"
                   Opacity="0.7"
                   VerticalAlignment="Center" />
    </StackPanel>
</UserControl>
