<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Dari.App.ViewModels"
        xmlns:views="using:Dari.App.Views"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        x:Class="Dari.App.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/dari.ico"
        Title="{Binding Title}"
        Width="1024"
        Height="680"
        MinWidth="640"
        MinHeight="480"
        DragDrop.AllowDrop="True">

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- Menu bar -->
        <Menu Grid.Row="0">
            <MenuItem Header="_File">
                <MenuItem Header="_Open…"
                          InputGesture="Ctrl+O"
                          Command="{Binding OpenArchiveCommand}" />
                <MenuItem Header="_Close"
                          InputGesture="Ctrl+W"
                          Command="{Binding CloseArchiveCommand}" />
                <Separator />
                <MenuItem Header="E_xit"
                          Command="{Binding ExitCommand}" />
            </MenuItem>
            <MenuItem Header="_Archive"
                      IsEnabled="{Binding Browser, Converter={x:Static ObjectConverters.IsNotNull}}">
                <MenuItem Header="Extract _All…"
                          InputGesture="Ctrl+E"
                          Command="{Binding Browser.ExtractAllCommand}" />
                <MenuItem Header="Extract _Selected…"
                          Command="{Binding Browser.ExtractSelectedCommand}" />
            </MenuItem>
            <MenuItem Header="_Help">
                <MenuItem Header="_About Dari" Command="{Binding AboutCommand}" />
            </MenuItem>
        </Menu>

        <!-- Main content area -->
        <Panel Grid.Row="1">

            <!-- Placeholder shown when no archive is open -->
            <TextBlock Text="Open a .dar archive to get started."
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Opacity="0.5"
                       FontSize="16"
                       IsVisible="{Binding Browser, Converter={x:Static ObjectConverters.IsNull}}" />

            <!-- Archive browser (visible when an archive is open) -->
            <ContentControl Content="{Binding Browser}">
                <ContentControl.DataTemplates>
                    <DataTemplate DataType="{x:Type vm:ArchiveBrowserViewModel}">
                        <views:ArchiveBrowserView />
                    </DataTemplate>
                </ContentControl.DataTemplates>
            </ContentControl>

        </Panel>

        <!-- Status bar -->
        <Border Grid.Row="2"
                BorderThickness="0,1,0,0"
                Padding="8,4">
            <TextBlock Text="{Binding StatusText}"
                       FontSize="12"
                       Opacity="0.7" />
        </Border>

    </Grid>

</Window>

